{
  "name": "chargebucks",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "dev:all": "bun run scripts/dev.ts",
    "dev:web": "cd web && bun run dev",
    "start": "bun run src/index.ts",
    "stripe:listen": "stripe listen --forward-to localhost:3000/webhook",
    "stripe:trigger": "stripe trigger charge.dispute.created",
    "typecheck": "tsc --noEmit && cd web && bunx tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "hono": "^4.6.0",
    "pdf-lib": "^1.17.1",
    "stripe": "^17.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  }
}
